datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

generator erd {
  provider = "prisma-erd-generator"
}

model Customer {
  id                String           @id @default(cuid())
  createdAt         DateTime         @default(now())
  deletedAt         DateTime?
  events            CustomerEvent[]
  customerSignals   CustomerSignal[]
  mergesAsCanonical MergeRecord[]    @relation("CanonicalMerges")
  mergesAsAbsorbed  MergeRecord[]    @relation("AbsorbedMerges")
}

model Event {
  id             String          @id @default(cuid())
  source         String // "shopify" | "mindbody"
  type           String // "order.created" | "booking.created"
  externalId     String          @unique
  payload        String // raw JSON
  occurredAt     DateTime
  createdAt      DateTime        @default(now())
  customerEvents CustomerEvent[]
}

model CustomerEvent {
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id])
  createdAt  DateTime @default(now())

  @@id([customerId, eventId])
}

model IdentitySignal {
  id              String           @id @default(cuid())
  type            String // "email" | "phone" | "device_id" | "shopify_customer_id" | "mindbody_client_id"
  value           String
  confidence      String           @default("deterministic") // "deterministic" | "probabilistic"
  expiresAt       DateTime? // set for short-lived signals e.g. fbclid, gclid
  createdAt       DateTime         @default(now())
  customerSignals CustomerSignal[]

  @@unique([type, value])
  @@index([value])
}

model MergeRecord {
  id              String   @id @default(cuid())
  canonicalId     String
  canonical       Customer @relation("CanonicalMerges", fields: [canonicalId], references: [id])
  absorbedId      String
  absorbed        Customer @relation("AbsorbedMerges", fields: [absorbedId], references: [id])
  signals         String // JSON of incoming signals that triggered the merge
  copiedSignalIds String   @default("[]") // JSON array of signalIds copied to canonical
  copiedEventIds  String   @default("[]") // JSON array of eventIds copied to canonical
  confidence      String   @default("deterministic") // "deterministic" | "probabilistic"
  createdAt       DateTime @default(now())
}

model CustomerSignal {
  customerId String
  customer   Customer       @relation(fields: [customerId], references: [id])
  signalId   String
  signal     IdentitySignal @relation(fields: [signalId], references: [id])
  createdAt  DateTime       @default(now())

  @@id([customerId, signalId])
}
